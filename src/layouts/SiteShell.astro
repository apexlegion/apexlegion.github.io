---
/**
 * SiteShell — composes BaseLayout with Header, Footer, and the
 * CommandPalette + MobileMenu React islands wired to global window events.
 *
 * Pages should use this as the outermost layout.
 *
 * Pass `lang` to render the page in a specific locale. The current locale is
 * also forwarded to the navigation so nav labels can be translated by passing
 * translated `navLinks` per page.
 */
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import RegisterSW from '@/components/pwa/RegisterSW';
import InstallPrompt from '@/components/pwa/InstallPrompt';
import { AIAssistant } from '@/components/assistant/AIAssistant';
import { DEFAULT_LOCALE, normalizeLocale, type Locale } from '@/i18n/utils';

export interface NavLink {
  label: string;
  href: string;
}

export interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  bodyClass?: string;
  lang?: string;
  /**
   * Override the navigation links (e.g. with translated labels for Spanish
   * pages). Defaults to the English nav.
   */
  navLinks?: NavLink[];
}

const navLinksEn: NavLink[] = [
  { label: 'Learn', href: '/learn' },
  { label: 'Projects', href: '/projects' },
  { label: 'Models', href: '/models' },
  { label: 'Glossary', href: '/glossary' },
  { label: 'Tools', href: '/tools' },
  { label: 'Playgrounds', href: '/playgrounds' },
  { label: 'Decisions', href: '/decisions' },
  { label: 'Compare', href: '/compare' },
  { label: 'Graph', href: '/graph' },
  { label: 'Jobs', href: '/jobs' },
  { label: 'Events', href: '/events' },
  { label: 'News', href: '/news' },
  { label: 'Dashboard', href: '/dashboard' },
];

const navLinksEs: NavLink[] = [
  { label: 'Aprende', href: '/es/learn' },
  { label: 'Proyectos', href: '/es/projects' },
  { label: 'Modelos', href: '/es/models' },
  { label: 'Glosario', href: '/es/glossary' },
  { label: 'Herramientas', href: '/es/tools' },
  { label: 'Playgrounds', href: '/es/playgrounds' },
  { label: 'Decisiones', href: '/es/decisions' },
  { label: 'Comparar', href: '/es/compare' },
  { label: 'Grafo', href: '/es/graph' },
  { label: 'Empleos', href: '/es/jobs' },
  { label: 'Eventos', href: '/es/events' },
  { label: 'Noticias', href: '/es/news' },
  { label: 'Panel', href: '/es/dashboard' },
];

const { title, description, image, noindex, bodyClass, lang, navLinks: navLinksProp } = Astro.props;
const resolvedLang: Locale = normalizeLocale(lang ?? DEFAULT_LOCALE);
const navLinks = navLinksProp ?? (resolvedLang === 'es' ? navLinksEs : navLinksEn);
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  noindex={noindex}
  bodyClass={bodyClass}
  lang={resolvedLang}
>
  <Header slot="header" links={navLinks} lang={resolvedLang} />
  <slot />
  <Footer slot="footer" lang={resolvedLang} />

  <RegisterSW client:load />
  <InstallPrompt client:load />
  <AIAssistant client:load />
</BaseLayout>

<script>
  import { createRoot, type Root } from 'react-dom/client';
  import { createElement } from 'react';
  import MobileMenuEl from '../components/layout/MobileMenu';
  import CommandPaletteEl from '../components/layout/CommandPalette';

  const PALETTE_TRIGGER_EVENT = 'palette:open';
  const MOBILE_OPEN_EVENT = 'mobile-menu:open';

  // Mount dynamic React roots for the menu/palette so they can mount/unmount
  // in response to global events. This keeps BaseLayout free of inline
  // client state.
  type PaletteRoot = { root: Root; setOpen: (open: boolean) => void };
  type MenuRoot = { root: Root; setOpen: (open: boolean) => void };

  const paletteState: PaletteRoot = (() => {
    const host = document.createElement('div');
    document.body.appendChild(host);
    const root = createRoot(host);
    let setOpen: (open: boolean) => void = () => undefined;
    const render = (open: boolean) =>
      root.render(createElement(CommandPaletteEl, { open, onClose: () => setOpen(false) }));
    render(false);
    setOpen = (open: boolean) => render(open);
    return { root, setOpen };
  })();

  const menuState: MenuRoot = (() => {
    const host = document.createElement('div');
    document.body.appendChild(host);
    const root = createRoot(host);
    const links = [
      { label: 'Projects', href: '/projects' },
      { label: 'Models', href: '/models' },
      { label: 'Glossary', href: '/glossary' },
      { label: 'Tools', href: '/tools' },
      { label: 'Playgrounds', href: '/playgrounds' },
      { label: 'Decisions', href: '/decisions' },
      { label: 'Concepts', href: '/concepts' },
      { label: 'Tutorials', href: '/tutorials' },
      { label: 'Compare', href: '/compare' },
      { label: 'Jobs', href: '/jobs' },
      { label: 'Events', href: '/events' },
      { label: 'News', href: '/news' },
      { label: 'Search', href: '/search' },
    ];
    let setOpen: (open: boolean) => void = () => undefined;
    const render = (open: boolean) =>
      root.render(createElement(MobileMenuEl, { open, onClose: () => setOpen(false), links }));
    render(false);
    setOpen = (open: boolean) => render(open);
    return { root, setOpen };
  })();

  window.addEventListener(PALETTE_TRIGGER_EVENT, () => paletteState.setOpen(true));
  window.addEventListener(MOBILE_OPEN_EVENT, () => menuState.setOpen(true));

  window.addEventListener('keydown', (e: KeyboardEvent) => {
    const target = e.target as HTMLElement | null;
    const isTyping =
      target &&
      (target.tagName === 'INPUT' ||
        target.tagName === 'TEXTAREA' ||
        (target as HTMLElement).isContentEditable);
    if (e.key === '/' && !isTyping) {
      e.preventDefault();
      paletteState.setOpen(true);
    }
  });
</script>
