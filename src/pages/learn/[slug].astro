---
/**
 * /learn/[slug] — a single Academy lesson.
 *
 * Fixed section order so every lesson reads the same way:
 * Goal → Tools (free-first + open-source badge) → Steps → Prompts (copyable)
 * → What you'll get → Make it yours → Words you just learned → Go deeper →
 * Mark done / next lesson.
 */
import SiteShell from '@/layouts/SiteShell.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { Badge } from '@/components/ui/Badge';
import { Tag } from '@/components/ui/Tag';
import { Button } from '@/components/ui/Button';
import { LessonDone, CopyPrompt } from '@/components/learn/LessonProgress';
import { withBase } from '@/lib';
import { LESSONS, getNextLesson, getTrack, type Lesson } from '@/data/lessons';

export async function getStaticPaths() {
  return LESSONS.map((lesson) => ({
    params: { slug: lesson.slug },
    props: { lesson },
  }));
}

const { lesson } = Astro.props as { lesson: Lesson };
const track = getTrack(lesson.track);
const next = getNextLesson(lesson);

const trackAnchor = `/learn#track-${lesson.track}`;
---

<SiteShell
  title={`${lesson.title} — Learn — AI Atlas`}
  description={lesson.tagline}
>
  <Container class="flex max-w-4xl flex-col gap-6 py-10">
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Learn', href: '/learn' },
        { label: lesson.title },
      ]}
    />

    <header class="flex flex-col gap-3">
      <div class="flex flex-wrap items-center gap-2">
        <Badge variant="tutorial">
          {track.emoji} {track.label}
        </Badge>
        <Tag>Lesson {lesson.order + 1}</Tag>
        <span class="text-text-subtle text-tiny font-mono">{lesson.minutes} min</span>
      </div>
      <h1 class="text-text text-h1 font-bold tracking-tight md:text-5xl">{lesson.title}</h1>
      <p class="text-text-muted text-body max-w-prose">{lesson.tagline}</p>
    </header>

    <Section>
      <div
        class="border-primary-orange/30 from-primary-orange/10 flex flex-col gap-2 rounded-2xl border bg-gradient-to-b to-transparent p-6"
      >
        <h2 class="text-primary-orange text-tiny font-semibold tracking-widest uppercase">
          What you'll be able to do
        </h2>
        <p class="text-text text-body">{lesson.goal}</p>
      </div>
    </Section>

    {
      (lesson.tool || lesson.oss) && (
        <Section>
          <div class="flex flex-col gap-3">
            <h2 class="text-text text-h3 font-semibold">Open one of these (both free)</h2>
            <div class="grid gap-4 md:grid-cols-2">
              {lesson.tool && (
                <a
                  href={lesson.tool.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group border-border bg-surface-card hover:border-primary-orange flex flex-col gap-1.5 rounded-xl border p-5 transition-colors"
                >
                  <span class="text-text-subtle text-tiny font-semibold tracking-widest uppercase">
                    Easiest start
                  </span>
                  <span class="text-text group-hover:text-primary-orange font-semibold transition-colors">
                    {lesson.tool.name} ↗
                  </span>
                  <span class="text-text-muted text-sm">{lesson.tool.note}</span>
                </a>
              )}
              {lesson.oss && (
                <a
                  href={lesson.oss.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group border-border bg-surface-card hover:border-primary-orange flex flex-col gap-1.5 rounded-xl border p-5 transition-colors"
                >
                  <span class="text-primary-orange text-tiny font-semibold tracking-widest uppercase">
                    ★ Open source
                  </span>
                  <span class="text-text group-hover:text-primary-orange font-semibold transition-colors">
                    {lesson.oss.name} ↗
                  </span>
                  <span class="text-text-muted text-sm">{lesson.oss.note}</span>
                </a>
              )}
            </div>
          </div>
        </Section>
      )
    }

    <Section>
      <div class="flex flex-col gap-3">
        <h2 class="text-text text-h3 font-semibold">Do this</h2>
        <ol class="flex flex-col gap-3">
          {
            lesson.steps.map((step, i) => (
              <li class="flex items-start gap-4">
                <span class="border-primary-orange/40 text-primary-orange mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full border font-mono text-sm font-bold">
                  {i + 1}
                </span>
                <p class="text-text-muted text-body">{step}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </Section>

    {
      lesson.prompts.length > 0 && (
        <Section>
          <div class="flex flex-col gap-4">
            <h2 class="text-text text-h3 font-semibold">
              {lesson.prompts.length === 1 ? 'Your copy-paste prompt' : 'Your copy-paste prompts'}
            </h2>
            {lesson.prompts.map((p) => (
              <div class="border-border bg-surface-card flex flex-col overflow-hidden rounded-xl border">
                <div class="border-border flex items-center justify-between gap-2 border-b px-4 py-2.5">
                  <span class="text-text-muted text-sm font-semibold">{p.label}</span>
                  <CopyPrompt client:load text={p.text} />
                </div>
                <pre class="text-text-muted overflow-x-auto p-4 font-mono text-sm leading-relaxed whitespace-pre-wrap">{p.text}</pre>
              </div>
            ))}
            <p class="text-text-subtle text-sm">
              Anything in [BRACKETS] is yours to fill in — replace it with your own details.
            </p>
          </div>
        </Section>
      )
    }

    <Section>
      <div class="flex flex-col gap-2">
        <h2 class="text-text text-h3 font-semibold">What you'll get</h2>
        <p class="text-text-muted text-body max-w-prose">{lesson.result}</p>
      </div>
    </Section>

    {
      lesson.tweaks.length > 0 && (
        <Section>
          <div class="flex flex-col gap-3">
            <h2 class="text-text text-h3 font-semibold">Make it yours</h2>
            <ul class="flex flex-col gap-2">
              {lesson.tweaks.map((tweak) => (
                <li class="text-text-muted text-body flex items-start gap-3">
                  <span class="text-primary-orange mt-1 shrink-0" aria-hidden="true">
                    →
                  </span>
                  {tweak}
                </li>
              ))}
            </ul>
          </div>
        </Section>
      )
    }

    {
      lesson.vocab.length > 0 && (
        <Section>
          <div class="border-border bg-surface-card flex flex-col gap-3 rounded-2xl border p-6">
            <h2 class="text-text text-h3 font-semibold">Words you just learned</h2>
            <div class="flex flex-col gap-3">
              {lesson.vocab.map((v) => (
                <a
                  href={withBase(v.href)}
                  class="group flex flex-col gap-0.5 rounded-lg transition-colors"
                >
                  <span class="text-primary-orange font-semibold group-hover:underline">
                    {v.term}
                  </span>
                  <span class="text-text-muted text-sm">{v.plain}</span>
                </a>
              ))}
            </div>
            <p class="text-text-subtle text-sm">
              Click any term for the full explanation — switchable from “Explain like I'm 12” up
              to Researcher level.
            </p>
          </div>
        </Section>
      )
    }

    {
      lesson.deeper.length > 0 && (
        <Section>
          <div class="flex flex-col gap-3">
            <h2 class="text-text text-h3 font-semibold">Go deeper</h2>
            <div class="flex flex-wrap gap-3">
              {lesson.deeper.map((link) => (
                <Button as="a" href={withBase(link.href)} variant="ghost" size="sm">
                  {link.label} →
                </Button>
              ))}
            </div>
          </div>
        </Section>
      )
    }

    <Section>
      <div
        class="border-border flex flex-col items-start justify-between gap-4 rounded-2xl border p-6 sm:flex-row sm:items-center"
      >
        <LessonDone client:load slug={lesson.slug} />
        {
          next ? (
            <Button as="a" href={withBase(`/learn/${next.slug}`)} variant="primary" size="md">
              Next: {next.title} →
            </Button>
          ) : (
            <Button as="a" href={withBase(trackAnchor)} variant="primary" size="md">
              Track complete — back to the Academy →
            </Button>
          )
        }
      </div>
    </Section>
  </Container>
</SiteShell>
