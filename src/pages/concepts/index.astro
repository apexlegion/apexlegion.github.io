---
import SiteShell from '@/layouts/SiteShell.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Grid from '@/components/layout/Grid.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { Card, CardBody, CardFooter, CardHeader } from '@/components/ui/Card';
import { Badge } from '@/components/ui/Badge';
import { Tag } from '@/components/ui/Tag';
import { Button } from '@/components/ui/Button';
import { getEntitiesByType } from '@/lib/data/entities';

const concepts = getEntitiesByType('concept');
---

<SiteShell title="Concepts — AI Atlas" description="AI concepts explained.">
  <Container class="flex flex-col gap-6 py-10">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Concepts' }]} />
    <header class="flex flex-col gap-2">
      <Badge variant="concept">Concepts</Badge>
      <h1 class="text-text text-h1 font-bold tracking-tight md:text-5xl">Concepts, explained</h1>
      <p class="text-text-muted text-body max-w-prose">
        Every concept is taught at the level that fits you — from "Like I'm 12" all the way to
        researcher.
      </p>
    </header>

    <Section containerSize="wide">
      <Grid cols={{ base: 1, md: 2, lg: 3 }} gap={6}>
        {
          concepts.map((c) => (
            <Card variant="interactive" href={`/concepts/${c.slug}`}>
              <CardHeader>
                <Tag>{c.level}</Tag>
                <h2 class="text-text text-h3 mt-2 font-semibold">{c.name}</h2>
              </CardHeader>
              <CardBody>{c.summary}</CardBody>
              <CardFooter>
                <Button variant="ghost" size="sm">
                  Read concept →
                </Button>
              </CardFooter>
            </Card>
          ))
        }
      </Grid>
    </Section>
  </Container>
</SiteShell>
