---
import SiteShell from '@/layouts/SiteShell.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Grid from '@/components/layout/Grid.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { Card, CardBody, CardFooter, CardHeader } from '@/components/ui/Card';
import { Badge } from '@/components/ui/Badge';
import { Tag } from '@/components/ui/Tag';
import { Button } from '@/components/ui/Button';
import { getAllNews, getAllJobs, isNewsExpired, isJobExpired } from '@/lib/data/entities';

const news = getAllNews();
const jobs = getAllJobs();
const totalExpired = [
  ...getAllJobs({ includeExpired: true }),
  ...getAllNews({ includeExpired: true }),
].filter((item) => (item.type === 'job' ? isJobExpired(item) : isNewsExpired(item))).length;

function formatDate(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<SiteShell
  title="News — AI Atlas"
  description="Latest launches, releases, and policy updates from across the Open Source AI universe."
>
  <Container class="flex flex-col gap-6 py-10">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'News' }]} />
    <header class="flex flex-col gap-2">
      <Badge variant="project">News</Badge>
      <h1 class="text-text text-h1 font-bold tracking-tight md:text-5xl">Open Source AI news</h1>
      <p class="text-text-muted text-body max-w-prose">
        Launches, releases, and policy updates from across the Open Source AI universe. Entries
        auto-expire after their <code class="font-mono">expiryAt</code> date.
      </p>
    </header>

    <Section containerSize="wide">
      {
        news.length === 0 ? (
          <Card class="p-8 text-center">
            <p class="text-text-muted text-body">
              No active news entries right now. Check back soon.
            </p>
          </Card>
        ) : (
          <Grid cols={{ base: 1, md: 2 }} gap={6}>
            {news.map((n) => (
              <Card variant="interactive" href={`/news/${n.slug}`}>
                <CardHeader>
                  <div class="flex flex-wrap items-center gap-2">
                    <Tag>{n.source}</Tag>
                    <span class="text-text-subtle text-tiny font-mono">
                      {formatDate(n.publishedAt)}
                    </span>
                  </div>
                  <h2 class="text-text text-h3 mt-2 font-semibold">{n.name}</h2>
                </CardHeader>
                <CardBody>{n.summary}</CardBody>
                <CardFooter>
                  <span class="text-text-subtle text-tiny font-mono">
                    Expires {formatDate(n.expiryAt)}
                  </span>
                  <span class="text-primary-orange text-small font-medium">Read →</span>
                </CardFooter>
              </Card>
            ))}
          </Grid>
        )
      }
    </Section>

    {
      totalExpired > 0 && (
        <p class="text-text-subtle text-tiny font-mono">
          {totalExpired} expired entries hidden from this listing.
        </p>
      )
    }
  </Container>
</SiteShell>
