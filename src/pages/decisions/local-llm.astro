---
import SiteShell from '@/layouts/SiteShell.astro';
import Container from '@/components/layout/Container.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { getDecisionProfileBySlug } from '@/lib/data/entities';
import { LocalLlmDecision } from '@/components/decisions/LocalLlmDecision';

const profile = getDecisionProfileBySlug('local-llm');
if (!profile) {
  throw new Error('Missing decision profile: local-llm');
}
---

<SiteShell title={`${profile.name} — AI Atlas`} description={profile.summary}>
  <Container class="flex flex-col gap-6 py-10">
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Decisions', href: '/decisions' },
        { label: profile.name },
      ]}
    />
    <LocalLlmDecision client:load profile={profile} />
  </Container>
</SiteShell>
