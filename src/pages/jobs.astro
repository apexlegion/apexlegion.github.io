---
import SiteShell from '@/layouts/SiteShell.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Grid from '@/components/layout/Grid.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { Card, CardBody, CardFooter, CardHeader } from '@/components/ui/Card';
import { Badge } from '@/components/ui/Badge';
import { Tag } from '@/components/ui/Tag';
import { Button } from '@/components/ui/Button';
import { getAllJobs } from '@/lib/data/entities';
import type { JobTypeValue } from '@/lib/schemas/entity';

const jobs = getAllJobs();

const jobTypeLabels: Record<JobTypeValue, string> = {
  'full-time': 'Full-time',
  'part-time': 'Part-time',
  contract: 'Contract',
  internship: 'Internship',
};

const jobTypes = Array.from(new Set(jobs.map((j) => j.jobType))).sort((a, b) =>
  jobTypeLabels[a].localeCompare(jobTypeLabels[b]),
);

function formatDate(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<SiteShell
  title="Jobs — AI Atlas"
  description="Open Source AI jobs, internships, and contracts. Filter by employment type."
>
  <Container class="flex flex-col gap-6 py-10">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Jobs' }]} />
    <header class="flex flex-col gap-2">
      <Badge variant="project">Jobs</Badge>
      <h1 class="text-text text-h1 font-bold tracking-tight md:text-5xl">Open Source AI jobs</h1>
      <p class="text-text-muted text-body max-w-prose">
        Roles at teams shipping open-weight models, open-source frameworks, and the tooling that
        makes them possible. Use the chips below to filter by employment type.
      </p>
    </header>

    <Section containerSize="wide">
      <div
        class="border-border bg-surface-card flex flex-col gap-3 rounded-lg border p-4"
        aria-label="Filter by job type"
      >
        <span class="text-text-muted text-tiny font-semibold tracking-wide uppercase">
          Filter by type
        </span>
        <div class="flex flex-wrap gap-2" role="list">
          <button
            type="button"
            data-job-filter="all"
            class="job-chip border-border bg-primary-orange text-text-inverse border-primary-orange text-small inline-flex h-9 items-center rounded-full border px-3 font-medium transition-colors"
            aria-pressed="true"
          >
            All ({jobs.length})
          </button>
          {
            jobTypes.map((type) => (
              <button
                type="button"
                data-job-filter={type}
                class="job-chip border-border bg-surface-elevated hover:border-primary-orange hover:text-primary-orange text-text-muted text-small inline-flex h-9 items-center rounded-full border px-3 font-medium transition-colors"
                aria-pressed="false"
              >
                {jobTypeLabels[type]} ({jobs.filter((j) => j.jobType === type).length})
              </button>
            ))
          }
        </div>
      </div>

      <div class="mt-6">
        {
          jobs.length === 0 ? (
            <Card class="p-8 text-center">
              <p class="text-text-muted text-body">
                No active job listings right now. Check back soon.
              </p>
            </Card>
          ) : (
            <Grid cols={{ base: 1, md: 2, lg: 3 }} gap={6}>
              {jobs.map((j) => (
                <Card
                  variant="interactive"
                  href={`/jobs/${j.slug}`}
                  data-job-type={j.jobType}
                  class="job-card"
                >
                  <CardHeader>
                    <div class="flex flex-wrap items-center gap-2">
                      <Tag>{jobTypeLabels[j.jobType]}</Tag>
                      <span class="text-text-subtle text-tiny font-mono">{j.location}</span>
                    </div>
                    <h2 class="text-text text-h3 mt-2 font-semibold">{j.name}</h2>
                    <p class="text-text-muted text-small">{j.company}</p>
                  </CardHeader>
                  <CardBody>{j.summary}</CardBody>
                  <CardFooter>
                    <span class="text-text-subtle text-tiny font-mono">
                      Posted {formatDate(j.postedAt)}
                    </span>
                    <span class="text-primary-orange text-small font-medium">View →</span>
                  </CardFooter>
                </Card>
              ))}
            </Grid>
          )
        }
      </div>
    </Section>
  </Container>

  <script>
    const chips = document.querySelectorAll<HTMLButtonElement>('[data-job-filter]');
    const cards = document.querySelectorAll<HTMLElement>('[data-job-type]');
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const target = chip.dataset.jobFilter ?? 'all';
        chips.forEach((c) => {
          const isActive = c === chip;
          c.setAttribute('aria-pressed', String(isActive));
          c.classList.toggle('bg-primary-orange', isActive);
          c.classList.toggle('text-text-inverse', isActive);
          c.classList.toggle('border-primary-orange', isActive);
          c.classList.toggle('bg-surface-elevated', !isActive);
          c.classList.toggle('text-text-muted', !isActive);
        });
        cards.forEach((card) => {
          const type = card.dataset.jobType;
          const visible = target === 'all' || type === target;
          card.classList.toggle('hidden', !visible);
        });
      });
    });
  </script>
</SiteShell>
