---
import SiteShell from '@/layouts/SiteShell.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { Card, CardBody, CardHeader } from '@/components/ui/Card';
import { Badge } from '@/components/ui/Badge';
import { Tag } from '@/components/ui/Tag';
import { Button } from '@/components/ui/Button';
import { getAllNews, getNewsBySlug, isNewsExpired } from '@/lib/data/entities';

export async function getStaticPaths() {
  // Include expired news in static paths so the detail page remains reachable
  // for direct links, even if it's hidden from the listing.
  return getAllNews({ includeExpired: true }).map((n) => ({
    params: { slug: n.slug },
    props: { news: n },
  }));
}

const { news } = Astro.props;
const expired = isNewsExpired(news);

function formatDate(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const verified = getNewsBySlug(news.slug);
if (!verified) {
  return Astro.redirect('/404');
}
---

<SiteShell title={`${news.name} — AI Atlas`} description={news.summary}>
  <Container class="flex flex-col gap-6 py-10">
    <Breadcrumbs
      items={[{ label: 'Home', href: '/' }, { label: 'News', href: '/news' }, { label: news.name }]}
    />

    <header class="flex flex-col gap-3">
      <div class="flex flex-wrap items-center gap-2">
        <Badge variant="project">News</Badge>
        <Tag>{news.source}</Tag>
        {expired ? <Badge variant="danger">Expired</Badge> : null}
      </div>
      <h1 class="text-text text-h1 font-bold tracking-tight md:text-5xl">{news.name}</h1>
      <p class="text-text-subtle text-tiny font-mono">
        Published {formatDate(news.publishedAt)} · Expires {formatDate(news.expiryAt)}
      </p>
      {news.author && <p class="text-text-muted text-small">By {news.author}</p>}
    </header>

    <Section containerSize="wide">
      <div class="grid gap-6 md:grid-cols-3">
        <article class="md:col-span-2">
          <Card>
            <CardHeader>
              <h2 class="text-text text-h3 font-semibold">Summary</h2>
            </CardHeader>
            <CardBody>
              <p class="text-text-muted text-body whitespace-pre-line">{news.description}</p>
            </CardBody>
          </Card>

          {
            news.tags.length > 0 && (
              <Card class="mt-6">
                <CardHeader>
                  <h2 class="text-text text-h3 font-semibold">Tags</h2>
                </CardHeader>
                <CardBody>
                  <div class="flex flex-wrap gap-2">
                    {news.tags.map((t) => (
                      <Tag>{t}</Tag>
                    ))}
                  </div>
                </CardBody>
              </Card>
            )
          }
        </article>

        <aside>
          <Card>
            <CardHeader>
              <h2 class="text-text text-h3 font-semibold">Links</h2>
            </CardHeader>
            <CardBody>
              {
                news.externalLinks.length === 0 ? (
                  <p class="text-text-muted text-small">No external links provided.</p>
                ) : (
                  <ul class="flex flex-col gap-2" role="list">
                    {news.externalLinks.map((link) => (
                      <li>
                        <a
                          href={link.href}
                          class="text-text hover:text-primary-orange text-small inline-flex items-center gap-1 font-medium underline-offset-4 hover:underline"
                          rel="noopener noreferrer"
                        >
                          {link.label} →
                        </a>
                      </li>
                    ))}
                  </ul>
                )
              }
            </CardBody>
          </Card>
        </aside>
      </div>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <Button variant="ghost" href="/news"> ← All news </Button>
      </div>
    </Section>
  </Container>
</SiteShell>
