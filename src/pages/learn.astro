---
/**
 * /learn — learning hub that surfaces tutorials and concepts.
 *
 * The "Learn" link appears in the global navigation; this page gives it a
 * dedicated landing surface and funnels visitors into the two primary
 * learning content types.
 */
import SiteShell from '@/layouts/SiteShell.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Grid from '@/components/layout/Grid.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { Card, CardBody, CardFooter, CardHeader } from '@/components/ui/Card';
import { Badge } from '@/components/ui/Badge';
import { Tag } from '@/components/ui/Tag';
import { Button } from '@/components/ui/Button';
import { getEntitiesByType } from '@/lib/data/entities';

const tutorials = getEntitiesByType('tutorial');
const concepts = getEntitiesByType('concept');

// "Start here" path — a guided, ordered sequence for someone with zero
// background. Each step points at a concept that ships a plain-language
// `twelve`/`beginner` explanation, so a non-technical reader can go from
// "what even is AI?" to running open models, one short read at a time.
const beginnerPath: { slug: string; blurb: string }[] = [
  { slug: 'artificial-intelligence', blurb: 'What AI actually is — in plain words.' },
  { slug: 'machine-learning', blurb: 'How computers learn from examples.' },
  { slug: 'neural-network', blurb: 'The brain-inspired math behind it all.' },
  { slug: 'large-language-model', blurb: 'The tech behind ChatGPT-style tools.' },
  { slug: 'training', blurb: 'How a model is taught before you use it.' },
  { slug: 'inference', blurb: 'What happens when you actually ask it something.' },
  { slug: 'prompt-engineering', blurb: 'How to ask so you get great answers.' },
  { slug: 'hallucination', blurb: 'Why AI sometimes makes things up.' },
  { slug: 'open-weights', blurb: 'Why "open source" AI is a big deal.' },
  { slug: 'ai-agent', blurb: 'When AI can take actions, not just chat.' },
];

const conceptBySlug = new Map(concepts.map((c) => [c.slug, c]));
const beginnerSteps = beginnerPath
  .map((step) => ({ ...step, concept: conceptBySlug.get(step.slug) }))
  .filter((step) => step.concept);
---

<SiteShell
  title="Learn — AI Atlas"
  description="Tutorials and concepts for every level of AI engineer."
>
  <Container class="flex flex-col gap-6 py-10">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Learn' }]} />
    <header class="flex flex-col gap-2">
      <Badge variant="tutorial">Learn</Badge>
      <h1 class="text-text text-h1 font-bold tracking-tight md:text-5xl">Learn Open Source AI</h1>
      <p class="text-text-muted text-body max-w-prose">
        Diagram-first tutorials and plain-language concepts, taught at the level that fits you.
      </p>
    </header>

    <Section>
      <div
        class="border-primary-orange/30 from-primary-orange/10 flex flex-col gap-5 rounded-2xl border bg-gradient-to-b to-transparent p-6 md:p-8"
      >
        <div class="flex flex-col gap-2">
          <Badge variant="tutorial">Start here · No experience needed</Badge>
          <h2 class="text-text text-h2 font-semibold">New to AI? Follow this path.</h2>
          <p class="text-text-muted text-body max-w-prose">
            Ten short reads that take you from “what even is AI?” to understanding how modern,
            free-to-run models work. Every step is written for a complete beginner — no coding, no
            maths, no jargon. Read them in order, or jump to whatever you're curious about.
          </p>
        </div>
        <ol class="flex flex-col gap-3">
          {
            beginnerSteps.map((step, idx) => (
              <li>
                <a
                  href={`/concepts/${step.slug}`}
                  class="group border-border bg-surface-card hover:border-primary-orange focus-visible:ring-primary-orange flex items-center gap-4 rounded-xl border p-4 transition-colors focus-visible:ring-2 focus-visible:outline-none"
                >
                  <span class="bg-primary-orange/15 text-primary-orange flex h-9 w-9 shrink-0 items-center justify-center rounded-full font-mono text-sm font-bold">
                    {idx + 1}
                  </span>
                  <span class="flex flex-col">
                    <span class="text-text group-hover:text-primary-orange font-semibold transition-colors">
                      {step.concept?.name}
                    </span>
                    <span class="text-text-muted text-small">{step.blurb}</span>
                  </span>
                  <span class="text-text-subtle group-hover:text-primary-orange ml-auto shrink-0 transition-colors">
                    →
                  </span>
                </a>
              </li>
            ))
          }
        </ol>
        <p class="text-text-subtle text-small">
          Tip: on every concept page you can switch the explanation between <strong
            class="text-text-muted">“Explain like I'm 12”</strong
          >, Beginner, Student, Developer, and Researcher.
        </p>
      </div>
    </Section>

    <Section>
      <div class="flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <h2 class="text-text text-h2 font-semibold">Tutorials</h2>
          <Button as="a" href="/tutorials" variant="ghost" size="sm">Browse all tutorials →</Button>
        </div>
        <Grid cols={{ base: 1, md: 2, lg: 3 }} gap={6}>
          {
            tutorials.slice(0, 3).map((t) => (
              <Card variant="interactive" href={`/tutorials/${t.slug}`}>
                <CardHeader>
                  <div class="flex flex-wrap items-center gap-2">
                    <Tag>{t.level}</Tag>
                    <Tag>{t.format}</Tag>
                  </div>
                  <h3 class="text-text text-h3 mt-2 font-semibold">{t.name}</h3>
                  <span class="text-text-subtle text-tiny mt-1 font-mono">
                    {t.durationMinutes} min
                  </span>
                </CardHeader>
                <CardBody>{t.summary}</CardBody>
                <CardFooter>
                  <Button variant="ghost" size="sm">
                    Start tutorial →
                  </Button>
                </CardFooter>
              </Card>
            ))
          }
        </Grid>
      </div>
    </Section>

    <Section>
      <div class="flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <h2 class="text-text text-h2 font-semibold">Concepts</h2>
          <Button as="a" href="/concepts" variant="ghost" size="sm">Browse all concepts →</Button>
        </div>
        <Grid cols={{ base: 1, md: 2, lg: 3 }} gap={6}>
          {
            concepts.slice(0, 3).map((c) => (
              <Card variant="interactive" href={`/concepts/${c.slug}`}>
                <CardHeader>
                  <Tag>{c.level}</Tag>
                  <h3 class="text-text text-h3 mt-2 font-semibold">{c.name}</h3>
                </CardHeader>
                <CardBody>{c.summary}</CardBody>
                <CardFooter>
                  <Button variant="ghost" size="sm">
                    Read concept →
                  </Button>
                </CardFooter>
              </Card>
            ))
          }
        </Grid>
      </div>
    </Section>
  </Container>
</SiteShell>
