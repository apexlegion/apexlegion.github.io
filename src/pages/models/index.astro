---
import SiteShell from '@/layouts/SiteShell.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Grid from '@/components/layout/Grid.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { Card, CardBody, CardFooter, CardHeader } from '@/components/ui/Card';
import { Badge } from '@/components/ui/Badge';
import { Tag } from '@/components/ui/Tag';
import { Button } from '@/components/ui/Button';
import ModelDirectoryFilters from '@/components/models/ModelDirectoryFilters.astro';
import { getEntitiesByType } from '@/lib/data/entities';

const models = getEntitiesByType('model');
---

<SiteShell title="Models — AI Atlas" description="Open-weight AI models.">
  <Container class="flex flex-col gap-6 py-10">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Models' }]} />
    <header class="flex flex-col gap-2">
      <Badge variant="model">Models</Badge>
      <h1 class="text-text text-h1 font-bold tracking-tight md:text-5xl">Open-weight models</h1>
      <p class="text-text-muted text-body max-w-prose">
        LLMs, image generators, and multimodal models with open weights — ready to run locally or
        self-host.
      </p>
    </header>

    <ModelDirectoryFilters />

    <Section containerSize="wide">
      <Grid cols={{ base: 1, md: 2, lg: 3 }} gap={6}>
        {
          models.map((m) => (
            <Card
              variant="interactive"
              href={`/models/${m.slug}`}
              data-model-card
              data-modality={m.modality}
              data-parameters={m.parameters ?? ''}
              data-name={m.name}
            >
              <CardHeader>
                <Tag>{m.modality}</Tag>
                <h2 class="text-text text-h3 mt-2 font-semibold">{m.name}</h2>
                {m.parameters ? (
                  <span class="text-text-subtle text-tiny mt-1 font-mono">{m.parameters}</span>
                ) : null}
              </CardHeader>
              <CardBody>{m.summary}</CardBody>
              <CardFooter>
                <Button variant="ghost" size="sm">
                  View model →
                </Button>
              </CardFooter>
            </Card>
          ))
        }
      </Grid>
    </Section>
  </Container>
</SiteShell>
