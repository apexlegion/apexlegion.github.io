---
import SiteShell from '@/layouts/SiteShell.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Grid from '@/components/layout/Grid.astro';
import { Button } from '@/components/ui/Button';
import { Card, CardBody, CardFooter, CardHeader } from '@/components/ui/Card';
import { Badge } from '@/components/ui/Badge';
import { Tag } from '@/components/ui/Tag';
import { getEntitiesByType } from '@/lib/data/entities';

const categories = [
  {
    badge: 'Start here' as const,
    title: 'Learn AI from zero',
    description: 'A plain-language path from “what is AI?” to running models — no coding needed.',
    href: '/learn',
    cta: 'Start learning',
  },
  {
    badge: 'Tools' as const,
    title: 'Open-source toolbox',
    description: 'The famous free GitHub tools everyone uses — what they do and how to use them.',
    href: '/tools',
    cta: 'Open the toolbox',
  },
  {
    badge: 'Projects' as const,
    title: 'Open Source projects',
    description: 'Curated repos for inference, training, agents, images, audio, and more.',
    href: '/projects',
    cta: 'Browse projects',
  },
  {
    badge: 'Models' as const,
    title: 'Open models',
    description: 'LLMs, image, audio, and multimodal models you can download and run today.',
    href: '/models',
    cta: 'Browse models',
  },
  {
    badge: 'Glossary' as const,
    title: 'AI Glossary A–Z',
    description: 'Plain-language definitions for every word you see in papers, docs, and demos.',
    href: '/glossary',
    cta: 'Browse glossary',
  },
  {
    badge: 'Playgrounds' as const,
    title: 'Playgrounds',
    description: 'Build intuition in your browser — tokenization, embeddings, RAG, and more.',
    href: '/playgrounds',
    cta: 'Open a playground',
  },
  {
    badge: 'Decisions' as const,
    title: 'Decision guides',
    description: 'Answer a few questions and get a recommended open-source tool for your goal.',
    href: '/decisions',
    cta: 'Get a recommendation',
  },
  {
    badge: 'Graph' as const,
    title: 'Knowledge graph',
    description: 'See how every project, model, and concept connects — and explore visually.',
    href: '/graph',
    cta: 'Explore the graph',
  },
];

// Pull real entities so the featured cards link to real detail pages.
const bySlug = (type: 'project' | 'model', slug: string) =>
  getEntitiesByType(type).find((e) => e.slug === slug);

const featuredProjects = [
  bySlug('project', 'llama-cpp'),
  bySlug('project', 'ollama'),
  bySlug('project', 'transformers'),
].filter(Boolean);

const featuredModels = [
  bySlug('model', 'llama-3'),
  bySlug('model', 'deepseek-r1'),
  bySlug('model', 'stable-diffusion-xl'),
].filter(Boolean);

const stats = [
  { value: `${getEntitiesByType('project').length}+`, label: 'Curated repos' },
  { value: `${getEntitiesByType('model').length}`, label: 'Open models' },
  { value: `${getEntitiesByType('concept').length}`, label: 'Glossary terms' },
  { value: '$0', label: 'Forever free' },
];

const beginnerSteps = [
  { slug: 'artificial-intelligence', name: 'What is AI?' },
  { slug: 'large-language-model', name: 'What is an LLM?' },
  { slug: 'open-weights', name: 'Why “open source” AI?' },
  { slug: 'inference', name: 'How do you run one?' },
];
---

<SiteShell
  title="AI Atlas"
  description="Learn. Compare. Build. Everything Open Source AI, in One Place."
  lang="en"
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div aria-hidden="true" class="bg-grid absolute inset-0 -z-10 h-[600px]"></div>
    <div
      aria-hidden="true"
      class="glow-brand -z-10 h-[520px] w-[820px]"
      style="left:50%;top:-160px;transform:translateX(-50%);"
    >
    </div>
    <Container class="flex flex-col items-center gap-7 py-20 text-center md:py-28">
      <a
        href="/learn"
        class="border-primary-orange/30 bg-primary-orange/10 text-primary-orange hover:bg-primary-orange/15 inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-medium transition-colors"
      >
        <span class="bg-primary-orange h-1.5 w-1.5 rounded-full"></span>
        New to AI? Start with zero knowledge →
      </a>
      <h1
        class="text-text max-w-4xl text-4xl font-bold tracking-tight text-balance md:text-6xl lg:text-7xl"
      >
        Everything
        <span class="text-gradient-brand">Open Source AI</span>,
        <br class="hidden md:block" /> explained for humans.
      </h1>
      <p class="text-text-muted max-w-2xl text-lg text-balance md:text-xl">
        Learn it, compare it, and build with it — using only free, open tools. Written so a complete
        beginner and a senior engineer both get value.
      </p>
      <div class="flex w-full max-w-lg items-center gap-2">
        <button
          type="button"
          data-palette-trigger
          class="border-border bg-surface-elevated/70 hover:border-primary-orange text-text-muted hover:text-text focus-visible:ring-primary-orange focus-visible:ring-offset-surface flex h-14 w-full items-center gap-3 rounded-xl border px-4 py-3 text-left backdrop-blur transition-colors focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
        >
          <svg
            class="h-5 w-5 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <span class="flex-1">Search projects, models, concepts…</span>
          <kbd class="bg-surface text-text-subtle text-tiny rounded px-1.5 py-0.5 font-mono">/</kbd>
        </button>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <Button as="a" href="/learn" size="lg" iconRight="→">Start learning free</Button>
        <Button as="a" href="/projects" size="lg" variant="secondary">Browse the tools</Button>
      </div>

      <!-- Stat row -->
      <dl class="mt-6 grid w-full max-w-2xl grid-cols-2 gap-4 sm:grid-cols-4">
        {
          stats.map((s) => (
            <div class="border-border bg-surface-card/50 flex flex-col items-center gap-1 rounded-xl border px-3 py-4 backdrop-blur">
              <dt class="text-gradient-brand text-2xl font-bold md:text-3xl">{s.value}</dt>
              <dd class="text-text-muted text-tiny tracking-wide uppercase">{s.label}</dd>
            </div>
          ))
        }
      </dl>
    </Container>
  </section>

  <!-- Beginner strip -->
  <Container class="pb-4">
    <div
      class="border-gradient-brand flex flex-col items-center gap-5 rounded-2xl p-6 md:flex-row md:justify-between md:p-8"
    >
      <div class="flex flex-col gap-1 text-center md:text-left">
        <span class="text-primary-orange text-tiny font-semibold tracking-wide uppercase"
          >No experience needed</span
        >
        <h2 class="text-text text-h3 font-semibold">Never touched AI before? Start right here.</h2>
      </div>
      <div class="flex flex-wrap justify-center gap-2">
        {
          beginnerSteps.map((step, i) => (
            <a
              href={`/concepts/${step.slug}`}
              class="border-border bg-surface-card hover:border-primary-orange text-text-muted hover:text-text inline-flex items-center gap-2 rounded-lg border px-3 py-2 text-sm font-medium transition-colors"
            >
              <span class="text-primary-orange font-mono text-xs">{i + 1}</span>
              {step.name}
            </a>
          ))
        }
      </div>
    </div>
  </Container>

  <!-- Categories -->
  <Section
    eyebrow="Explore"
    title="Everything, one click away"
    description="Whatever you're here for — pick a lane and dive in."
    containerSize="wide"
  >
    <Grid cols={{ base: 1, md: 2, lg: 4 }} gap={6}>
      {
        categories.map((cat) => (
          <Card variant="interactive" href={cat.href} className="group h-full">
            <CardHeader>
              <Badge variant="project">{cat.badge}</Badge>
              <h3 class="text-text group-hover:text-primary-orange text-h3 mt-3 font-semibold transition-colors">
                {cat.title}
              </h3>
            </CardHeader>
            <CardBody>{cat.description}</CardBody>
            <CardFooter>
              <span class="text-primary-orange text-small font-medium">{cat.cta} →</span>
            </CardFooter>
          </Card>
        ))
      }
    </Grid>
  </Section>

  <!-- Featured projects -->
  <Section
    eyebrow="Popular tools"
    title="The repos everyone's using"
    description="Famous, battle-tested open-source AI projects — each with a plain-English explainer."
    containerSize="wide"
  >
    <Grid cols={{ base: 1, md: 3 }} gap={6}>
      {
        featuredProjects.map((p) => (
          <Card variant="interactive" href={`/projects/${p!.slug}`} className="group h-full">
            <CardHeader>
              <Tag>{(p as { category?: string }).category ?? 'Project'}</Tag>
              <h3 class="text-text group-hover:text-primary-orange text-h3 mt-2 font-semibold transition-colors">
                {p!.name}
              </h3>
            </CardHeader>
            <CardBody>{p!.summary}</CardBody>
            <CardFooter>
              <span class="text-primary-orange text-small font-medium">Open →</span>
            </CardFooter>
          </Card>
        ))
      }
    </Grid>
    <div class="mt-6 flex justify-center">
      <Button as="a" href="/projects" variant="secondary">See all projects →</Button>
    </div>
  </Section>

  <!-- Featured models -->
  <Section
    eyebrow="Models"
    title="Open models you can run today"
    description="From tiny laptop-friendly models to frontier reasoners — all open weights."
    containerSize="wide"
  >
    <Grid cols={{ base: 1, md: 3 }} gap={6}>
      {
        featuredModels.map((m) => (
          <Card variant="interactive" href={`/models/${m!.slug}`} className="group h-full">
            <CardHeader>
              <Tag>{(m as { modality?: string }).modality ?? 'Model'}</Tag>
              <h3 class="text-text group-hover:text-primary-orange text-h3 mt-2 font-semibold transition-colors">
                {m!.name}
              </h3>
            </CardHeader>
            <CardBody>{m!.summary}</CardBody>
            <CardFooter>
              <span class="text-primary-orange text-small font-medium">Details →</span>
            </CardFooter>
          </Card>
        ))
      }
    </Grid>
    <div class="mt-6 flex justify-center">
      <Button as="a" href="/models" variant="secondary">See all models →</Button>
    </div>
  </Section>

  <!-- Knowledge graph CTA -->
  <Section containerSize="wide">
    <div class="border-border relative overflow-hidden rounded-2xl border p-8 text-center md:p-12">
      <div aria-hidden="true" class="glow-brand h-64 w-64" style="right:-40px;bottom:-60px;"></div>
      <div class="relative flex flex-col items-center gap-4">
        <Badge variant="concept">Knowledge graph</Badge>
        <h2 class="text-text max-w-2xl text-3xl font-bold md:text-4xl">
          See how the whole universe connects
        </h2>
        <p class="text-text-muted max-w-prose">
          Every project, model, and concept is one connected graph. Click any node to expand its
          neighbourhood and follow the threads.
        </p>
        <Button as="a" href="/graph" size="lg">Explore the graph →</Button>
      </div>
    </div>
  </Section>
</SiteShell>
