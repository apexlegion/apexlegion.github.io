[
  {
    "slug": "local-llm",
    "name": "Choose a Local LLM Tool",
    "summary": "Pick the right local-LLM tool for your hardware and use case.",
    "description": "Answer a few quick questions about how you plan to use a local LLM and we'll recommend a project from the AI Atlas catalog.",
    "questions": [
      {
        "id": "use-case",
        "prompt": "What will you mostly use it for?",
        "helperText": "Different tools shine at different tasks.",
        "type": "single",
        "options": [
          { "value": "chat", "label": "Chatting with a single model" },
          { "value": "dev", "label": "Embedding a model into an app" },
          { "value": "experiments", "label": "Running benchmarks / experiments" },
          { "value": "tinkering", "label": "Just tinkering, no specific goal" }
        ]
      },
      {
        "id": "hardware",
        "prompt": "What's your hardware?",
        "helperText": "We pick tools that fit your machine.",
        "type": "single",
        "options": [
          { "value": "apple-silicon", "label": "Apple Silicon (M1/M2/M3/M4)" },
          { "value": "nvidia-gpu", "label": "NVIDIA GPU with CUDA" },
          { "value": "cpu-only", "label": "CPU only, modest RAM" }
        ]
      },
      {
        "id": "license",
        "prompt": "Do you have a license preference?",
        "type": "single",
        "options": [
          { "value": "any", "label": "Any open license is fine" },
          { "value": "permissive", "label": "Permissive (MIT/Apache) preferred" }
        ]
      }
    ],
    "rules": [
      {
        "when": { "all": ["chat", "apple-silicon", "any"] },
        "recommendations": [
          {
            "slug": "ollama",
            "type": "project",
            "reason": "Ollama gives you a one-command setup for chatting on Apple Silicon."
          },
          {
            "slug": "llama-cpp",
            "type": "project",
            "reason": "llama.cpp is the underlying engine and is rock-solid on Apple Silicon."
          }
        ]
      },
      {
        "when": { "all": ["chat", "nvidia-gpu", "any"] },
        "recommendations": [
          {
            "slug": "ollama",
            "type": "project",
            "reason": "Ollama automatically picks CUDA when available."
          },
          {
            "slug": "text-generation-webui",
            "type": "project",
            "reason": "text-generation-webui exposes more knobs for GPU users."
          }
        ]
      },
      {
        "when": { "all": ["chat", "cpu-only", "any"] },
        "recommendations": [
          {
            "slug": "llama-cpp",
            "type": "project",
            "reason": "llama.cpp is the most mature CPU-only inference path."
          },
          {
            "slug": "ollama",
            "type": "project",
            "reason": "Ollama wraps llama.cpp and ships quantized models tuned for low-RAM machines."
          }
        ]
      },
      {
        "when": { "all": ["dev"] },
        "recommendations": [
          {
            "slug": "ollama",
            "type": "project",
            "reason": "Ollama's local REST API is the easiest way to embed a model in an app."
          },
          {
            "slug": "llama-cpp",
            "type": "project",
            "reason": "Use llama.cpp directly when you need fine-grained control from C/C++ or Python."
          }
        ]
      },
      {
        "when": { "all": ["experiments"] },
        "recommendations": [
          {
            "slug": "text-generation-webui",
            "type": "project",
            "reason": "text-generation-webui exposes many sampling and evaluation switches."
          }
        ]
      },
      {
        "when": { "all": ["tinkering"] },
        "recommendations": [
          {
            "slug": "ollama",
            "type": "project",
            "reason": "Ollama is the lowest-friction way to try open models locally."
          }
        ]
      }
    ],
    "tags": ["local-llm", "inference", "recommendation"],
    "externalLinks": []
