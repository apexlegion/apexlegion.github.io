---
/**
 * Section — page section with optional title/eyebrow/description.
 *
 * Slots:
 *   - `actions` — section-level actions (e.g. "View all" link)
 *   - default    — section content
 */
export interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  id?: string;
  class?: string;
  containerSize?: 'content' | 'wide' | 'prose';
}

const {
  eyebrow,
  title,
  description,
  id,
  class: className = '',
  containerSize = 'content',
} = Astro.props;

const containerClass = {
  content: 'mx-auto w-full max-w-container px-4 md:px-8',
  wide: 'mx-auto w-full max-w-dashboard px-4 md:px-8',
  prose: 'mx-auto w-full max-w-prose px-4 md:px-8',
}[containerSize];
---

<section id={id} class:list={['py-12 md:py-16', className]}>
  <div class={containerClass}>
    {
      (eyebrow || title || description) && (
        <header class="mb-8 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
          <div class="flex flex-col gap-2">
            {eyebrow && (
              <span class="text-tiny text-primary-orange font-mono tracking-wide uppercase">
                {eyebrow}
              </span>
            )}
            {title && <h2 class="text-h2 text-text font-bold">{title}</h2>}
            {description && <p class="text-body text-text-muted max-w-prose">{description}</p>}
          </div>
          <div class="flex shrink-0 items-center gap-2">
            <slot name="actions" />
          </div>
        </header>
      )
    }
    <slot />
  </div>
</section>
